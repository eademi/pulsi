{
  "name": "pulsi",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "db:down": "docker compose down",
    "db:generate:api": "pnpm --filter @pulsi/api db:generate",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate:api": "pnpm --filter @pulsi/api db:migrate",
    "db:ps": "docker compose ps",
    "db:up": "docker compose up -d postgres",
    "db:up:tools": "docker compose --profile tools up -d",
    "dev:api": "pnpm --filter @pulsi/api dev",
    "dev:client": "pnpm --filter @pulsi/client dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @pulsi/shared build && pnpm --filter @pulsi/api exec tsc --noEmit && pnpm --filter @pulsi/client exec tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
